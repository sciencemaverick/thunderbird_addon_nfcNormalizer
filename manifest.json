{
  "manifest_version": 3,
  "name": "Korean Attachment NFC Normalizer",
  "description": "Normalizes Thunderbird compose attachment display names to Unicode NFC on macOS without renaming the original file.",
  "version": "0.1.0",
  "author": "Jake + Codex",
  "homepage_url": "https://github.com/sciencemaverick/thunderbird_addon_nfcNormalizer",
  "icons": {
    "16": "icons/icon.svg",
    "32": "icons/icon.svg",
    "64": "icons/icon.svg",
    "128": "icons/icon.svg"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "korean-attachment-nfc-normalizer@addons.thunderbird.local",
      "strict_min_version": "140.0"
    }
  },
  "background": {
    "scripts": [
      "background.js"
    ],
    "type": "module"
  },
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },
  "permissions": [
    "compose",
    "downloads",
    "storage"
  ]
}
